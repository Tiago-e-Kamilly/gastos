<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Controle de Gastos Pessoal</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #f7f6f3;
    --surface: #ffffff;
    --surface2: #f0efe9;
    --border: rgba(0,0,0,0.08);
    --border2: rgba(0,0,0,0.13);
    --text: #1a1a18;
    --text2: #6b6a65;
    --text3: #a09f9a;
    --green: #1a9e72;
    --green-bg: #e2f5ec;
    --red: #d85a30;
    --red-bg: #faecea;
    --blue: #2e6db4;
    --blue-bg: #e6f0fb;
    --amber: #b87515;
    --amber-bg: #fdf0d5;
    --purple: #7a6fc0;
    --purple-bg: #efedfc;
    --radius: 12px;
    --radius-sm: 8px;
    --shadow: 0 1px 3px rgba(0,0,0,0.07), 0 4px 16px rgba(0,0,0,0.05);
    --font: 'DM Sans', sans-serif;
    --font-mono: 'DM Mono', monospace;
  }

  [data-theme="dark"] {
    --bg: #111110;
    --surface: #1c1c1a;
    --surface2: #242422;
    --border: rgba(255,255,255,0.08);
    --border2: rgba(255,255,255,0.14);
    --text: #f0efe9;
    --text2: #9a9990;
    --text3: #5a5955;
    --green: #2ec98e;
    --green-bg: #0d2e20;
    --red: #e8714c;
    --red-bg: #2e160c;
    --blue: #6aa3e0;
    --blue-bg: #0e1f35;
    --amber: #e8a030;
    --amber-bg: #2a1d08;
    --purple: #a89de8;
    --purple-bg: #1e1b38;
    --shadow: 0 1px 3px rgba(0,0,0,0.3), 0 4px 16px rgba(0,0,0,0.2);
  }

  html { font-size: 15px; }
  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    transition: background 0.2s, color 0.2s;
  }

  /* ---- LAYOUT ---- */
  .layout { display: flex; min-height: 100vh; }

  .sidebar {
    width: 220px;
    flex-shrink: 0;
    background: var(--surface);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    padding: 1.5rem 1rem;
    position: fixed;
    top: 0; left: 0; bottom: 0;
    z-index: 100;
    transition: transform 0.25s;
  }

  .sidebar-logo {
    font-size: 17px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 2rem;
    padding: 0 0.5rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .sidebar-logo .logo-icon {
    width: 32px; height: 32px;
    background: var(--green);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    color: #fff;
    font-size: 15px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    border-radius: var(--radius-sm);
    font-size: 14px;
    color: var(--text2);
    cursor: pointer;
    margin-bottom: 2px;
    transition: background 0.15s, color 0.15s;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
  }
  .nav-item:hover { background: var(--surface2); color: var(--text); }
  .nav-item.active { background: var(--surface2); color: var(--text); font-weight: 500; }
  .nav-item i { width: 18px; text-align: center; font-size: 15px; }

  .sidebar-footer { margin-top: auto; padding-top: 1rem; border-top: 1px solid var(--border); }

  .main { margin-left: 220px; flex: 1; padding: 2rem; max-width: 1100px; }

  /* ---- TOPBAR ---- */
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }
  .topbar-left h1 { font-size: 22px; font-weight: 600; }
  .topbar-left p { font-size: 13px; color: var(--text2); margin-top: 2px; }
  .topbar-right { display: flex; align-items: center; gap: 10px; }

  .btn-icon {
    width: 36px; height: 36px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border2);
    background: var(--surface);
    color: var(--text2);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 15px;
    transition: background 0.15s;
  }
  .btn-icon:hover { background: var(--surface2); color: var(--text); }

  /* ---- CARDS ---- */
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 14px;
    margin-bottom: 2rem;
  }

  .metric-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.2rem 1.4rem;
    box-shadow: var(--shadow);
  }
  .metric-card .mc-label {
    font-size: 12px;
    color: var(--text2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .metric-card .mc-value {
    font-size: 24px;
    font-weight: 600;
    font-family: var(--font-mono);
  }
  .metric-card .mc-sub {
    font-size: 12px;
    color: var(--text3);
    margin-top: 4px;
  }
  .mc-value.green { color: var(--green); }
  .mc-value.red { color: var(--red); }

  /* ---- PANEL ---- */
  .panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.4rem;
    margin-bottom: 1.5rem;
  }
  .panel-title {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text2);
    margin-bottom: 1.1rem;
  }

  /* ---- GRID ---- */
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.5rem; }

  /* ---- TRANSACTIONS ---- */
  .tx-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }
  .tx-item:last-child { border-bottom: none; }
  .tx-icon {
    width: 38px; height: 38px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
  }
  .tx-info { flex: 1; min-width: 0; }
  .tx-name { font-size: 14px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .tx-cat { font-size: 12px; color: var(--text2); margin-top: 1px; }
  .tx-date { font-size: 12px; color: var(--text3); margin-right: 6px; white-space: nowrap; }
  .tx-amount { font-size: 14px; font-weight: 600; font-family: var(--font-mono); white-space: nowrap; }
  .tx-amount.inc { color: var(--green); }
  .tx-amount.exp { color: var(--red); }
  .tx-delete {
    background: none; border: none; color: var(--text3);
    cursor: pointer; font-size: 13px; padding: 4px;
    border-radius: 4px; opacity: 0;
    transition: opacity 0.15s, color 0.15s;
  }
  .tx-item:hover .tx-delete { opacity: 1; }
  .tx-delete:hover { color: var(--red); }

  /* ---- CATEGORY BARS ---- */
  .cat-row { margin-bottom: 14px; }
  .cat-row:last-child { margin-bottom: 0; }
  .cat-row-top { display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 5px; }
  .cat-name { color: var(--text2); display: flex; align-items: center; gap: 7px; }
  .cat-val { font-weight: 500; font-family: var(--font-mono); }
  .bar-bg { height: 6px; background: var(--surface2); border-radius: 3px; overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 3px; transition: width 0.6s cubic-bezier(.4,0,.2,1); }

  /* ---- FORM ---- */
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }
  .form-full { grid-column: 1 / -1; }
  label.field-label { font-size: 12px; font-weight: 500; color: var(--text2); display: block; margin-bottom: 5px; text-transform: uppercase; letter-spacing: 0.04em; }
  input, select, textarea {
    width: 100%;
    padding: 9px 12px;
    border: 1px solid var(--border2);
    border-radius: var(--radius-sm);
    background: var(--surface);
    color: var(--text);
    font-family: var(--font);
    font-size: 14px;
    transition: border-color 0.15s;
  }
  input:focus, select:focus { outline: none; border-color: var(--green); }

  .type-toggle { display: flex; gap: 8px; margin-bottom: 16px; }
  .type-btn {
    flex: 1; padding: 10px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border2);
    font-size: 14px; font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
    background: var(--surface);
    color: var(--text2);
  }
  .type-btn.active-exp { background: var(--red-bg); color: var(--red); border-color: var(--red); }
  .type-btn.active-inc { background: var(--green-bg); color: var(--green); border-color: var(--green); }

  .btn-primary {
    width: 100%;
    padding: 11px;
    background: var(--green);
    color: #fff;
    border: none;
    border-radius: var(--radius-sm);
    font-family: var(--font);
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    margin-top: 8px;
    transition: opacity 0.15s, transform 0.1s;
  }
  .btn-primary:hover { opacity: 0.9; }
  .btn-primary:active { transform: scale(0.98); }

  /* ---- GOALS ---- */
  .goal-item { padding: 14px 0; border-bottom: 1px solid var(--border); }
  .goal-item:last-child { border-bottom: none; }
  .goal-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px; }
  .goal-name { font-size: 14px; font-weight: 500; }
  .goal-pct { font-size: 13px; font-weight: 600; font-family: var(--font-mono); color: var(--green); }
  .goal-bar-bg { height: 8px; background: var(--surface2); border-radius: 4px; overflow: hidden; margin-bottom: 5px; }
  .goal-bar-fill { height: 100%; background: var(--green); border-radius: 4px; transition: width 0.6s cubic-bezier(.4,0,.2,1); }
  .goal-sub { display: flex; justify-content: space-between; font-size: 12px; color: var(--text3); font-family: var(--font-mono); }

  /* ---- BADGES ---- */
  .badge {
    font-size: 11px; font-weight: 500;
    padding: 2px 8px;
    border-radius: 99px;
    display: inline-block;
  }

  /* ---- FILTER ---- */
  .filter-bar { display: flex; gap: 6px; margin-bottom: 14px; flex-wrap: wrap; }
  .filter-chip {
    font-size: 12px; font-weight: 500;
    padding: 5px 14px;
    border-radius: 99px;
    border: 1px solid var(--border2);
    background: var(--surface);
    color: var(--text2);
    cursor: pointer;
    transition: all 0.15s;
  }
  .filter-chip.active {
    background: var(--text);
    color: var(--bg);
    border-color: transparent;
  }

  /* ---- MONTH NAV ---- */
  .month-nav { display: flex; align-items: center; gap: 12px; margin-bottom: 1.5rem; }
  .month-nav button {
    background: var(--surface); border: 1px solid var(--border2);
    border-radius: var(--radius-sm); padding: 7px 14px;
    font-family: var(--font); font-size: 13px; cursor: pointer; color: var(--text);
    transition: background 0.15s;
  }
  .month-nav button:hover { background: var(--surface2); }
  .month-nav .month-label { font-size: 16px; font-weight: 600; flex: 1; }

  /* ---- PAGE VISIBILITY ---- */
  .page { display: none; }
  .page.active { display: block; }

  /* ---- HAMBURGER (MOBILE) ---- */
  .hamburger {
    display: none;
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: var(--radius-sm);
    padding: 8px 10px;
    cursor: pointer;
    color: var(--text);
    font-size: 16px;
  }
  .sidebar-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.35);
    z-index: 99;
  }

  /* ---- FEEDBACK ---- */
  #add-feedback {
    font-size: 13px;
    text-align: center;
    height: 18px;
    margin-top: 8px;
  }

  /* ---- EMPTY STATE ---- */
  .empty { font-size: 13px; color: var(--text3); text-align: center; padding: 2rem 0; }

  /* ---- RESPONSIVE ---- */
  @media (max-width: 768px) {
    .sidebar { transform: translateX(-100%); }
    .sidebar.open { transform: translateX(0); }
    .sidebar-overlay.open { display: block; }
    .main { margin-left: 0; padding: 1.2rem; }
    .hamburger { display: flex; }
    .grid-2, .grid-3 { grid-template-columns: 1fr; }
    .metrics-grid { grid-template-columns: 1fr 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }
  @media (max-width: 420px) {
    .metrics-grid { grid-template-columns: 1fr; }
  }

  /* ---- SCROLLBAR ---- */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }

  /* ---- CHART LEGEND ---- */
  .chart-legend { display: flex; gap: 16px; margin-bottom: 10px; font-size: 12px; color: var(--text2); }
  .chart-legend span { display: flex; align-items: center; gap: 5px; }
  .legend-dot { width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; }

  /* ---- TOAST ---- */
  #toast {
    position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(20px);
    background: var(--text); color: var(--bg);
    padding: 10px 20px; border-radius: var(--radius-sm);
    font-size: 13px; font-weight: 500;
    opacity: 0; transition: all 0.25s;
    z-index: 999; pointer-events: none;
    white-space: nowrap;
  }
  #toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
</style>
</head>
<body>

<div id="toast"></div>

<div class="layout">
  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <div class="logo-icon"><i class="fa-solid fa-wallet"></i></div>
      FinançasPRO
    </div>

    <button class="nav-item active" onclick="switchPage('dashboard', this)">
      <i class="fa-solid fa-chart-pie"></i> Painel
    </button>
    <button class="nav-item" onclick="switchPage('transactions', this)">
      <i class="fa-solid fa-list-ul"></i> Transações
    </button>
    <button class="nav-item" onclick="switchPage('add', this)">
      <i class="fa-solid fa-plus"></i> Adicionar
    </button>
    <button class="nav-item" onclick="switchPage('goals', this)">
      <i class="fa-solid fa-bullseye"></i> Metas
    </button>
    <button class="nav-item" onclick="switchPage('stats', this)">
      <i class="fa-solid fa-chart-line"></i> Estatísticas
    </button>

    <div class="sidebar-footer">
      <button class="nav-item" onclick="toggleTheme()">
        <i class="fa-solid fa-moon" id="theme-icon"></i> <span id="theme-label">Modo escuro</span>
      </button>
    </div>
  </aside>

  <div class="sidebar-overlay" id="sidebar-overlay" onclick="closeSidebar()"></div>

  <!-- MAIN -->
  <main class="main">
    <div class="topbar">
      <div class="topbar-left">
        <h1 id="page-heading">Painel</h1>
        <p id="today-str"></p>
      </div>
      <div class="topbar-right">
        <button class="btn-icon hamburger" onclick="openSidebar()" aria-label="Menu">
          <i class="fa-solid fa-bars"></i>
        </button>
        <button class="btn-icon" onclick="exportCSV()" title="Exportar CSV">
          <i class="fa-solid fa-download"></i>
        </button>
        <button class="btn-icon" onclick="switchPage('add', null)" title="Nova transação">
          <i class="fa-solid fa-plus"></i>
        </button>
      </div>
    </div>

    <!-- ========== DASHBOARD ========== -->
    <div class="page active" id="page-dashboard">
      <div class="month-nav">
        <button onclick="changeMonth(-1)"><i class="fa-solid fa-chevron-left"></i></button>
        <span class="month-label" id="month-display"></span>
        <button onclick="changeMonth(1)"><i class="fa-solid fa-chevron-right"></i></button>
      </div>

      <div class="metrics-grid" id="metrics-grid"></div>

      <div class="grid-2">
        <div class="panel">
          <div class="panel-title">Gastos por categoria</div>
          <div id="cat-bars"></div>
        </div>
        <div class="panel">
          <div class="panel-title">Evolução mensal</div>
          <div class="chart-legend">
            <span><span class="legend-dot" style="background:#1a9e72"></span>Receitas</span>
            <span><span class="legend-dot" style="background:#d85a30; border-radius:2px; border-top:2px dashed #d85a30; background:transparent; width:14px; height:2px; margin-top:4px;"></span>Despesas</span>
          </div>
          <div style="position:relative; height:200px;">
            <canvas id="trend-chart" role="img" aria-label="Gráfico de tendência de receitas e despesas nos últimos 6 meses"></canvas>
          </div>
        </div>
      </div>

      <div class="panel">
        <div class="panel-title">Últimas transações</div>
        <div id="recent-list"></div>
      </div>
    </div>

    <!-- ========== TRANSACTIONS ========== -->
    <div class="page" id="page-transactions">
      <div class="filter-bar">
        <button class="filter-chip active" onclick="setFilter('all', this)">Todos</button>
        <button class="filter-chip" onclick="setFilter('income', this)">Receitas</button>
        <button class="filter-chip" onclick="setFilter('expense', this)">Despesas</button>
      </div>
      <div class="panel">
        <div id="all-tx-list"></div>
      </div>
    </div>

    <!-- ========== ADD ========== -->
    <div class="page" id="page-add">
      <div style="max-width:520px;">
        <div class="panel">
          <div class="panel-title">Nova transação</div>
          <div class="type-toggle">
            <button class="type-btn active-exp" id="btn-exp" onclick="setTxType('expense')">
              <i class="fa-solid fa-arrow-trend-down"></i> Despesa
            </button>
            <button class="type-btn" id="btn-inc" onclick="setTxType('income')">
              <i class="fa-solid fa-arrow-trend-up"></i> Receita
            </button>
          </div>

          <div class="form-row">
            <div class="form-full">
              <label class="field-label">Descrição</label>
              <input type="text" id="tx-desc" placeholder="Ex: Supermercado, Salário...">
            </div>
            <div>
              <label class="field-label">Valor (R$)</label>
              <input type="number" id="tx-amount" placeholder="0,00" min="0" step="0.01">
            </div>
            <div>
              <label class="field-label">Data</label>
              <input type="date" id="tx-date">
            </div>
            <div class="form-full">
              <label class="field-label">Categoria</label>
              <select id="tx-cat">
                <optgroup label="Despesas">
                  <option>Alimentação</option>
                  <option>Transporte</option>
                  <option>Moradia</option>
                  <option>Saúde</option>
                  <option>Lazer</option>
                  <option>Educação</option>
                  <option>Vestuário</option>
                  <option>Assinaturas</option>
                  <option>Outros</option>
                </optgroup>
                <optgroup label="Receitas">
                  <option>Salário</option>
                  <option>Freelance</option>
                  <option>Investimentos</option>
                  <option>Extras</option>
                </optgroup>
              </select>
            </div>
          </div>

          <button class="btn-primary" onclick="addTransaction()">
            <i class="fa-solid fa-plus"></i> Adicionar transação
          </button>
          <div id="add-feedback"></div>
        </div>
      </div>
    </div>

    <!-- ========== GOALS ========== -->
    <div class="page" id="page-goals">
      <div class="grid-2">
        <div class="panel">
          <div class="panel-title">Minhas metas</div>
          <div id="goals-list"></div>
        </div>
        <div class="panel">
          <div class="panel-title">Nova meta</div>
          <div style="margin-bottom:12px;">
            <label class="field-label">Nome da meta</label>
            <input type="text" id="goal-name" placeholder="Ex: Viagem, Carro, Reserva...">
          </div>
          <div class="form-row">
            <div>
              <label class="field-label">Valor alvo (R$)</label>
              <input type="number" id="goal-target" placeholder="0,00" min="0" step="0.01">
            </div>
            <div>
              <label class="field-label">Já guardado (R$)</label>
              <input type="number" id="goal-saved" placeholder="0,00" min="0" step="0.01">
            </div>
          </div>
          <button class="btn-primary" onclick="addGoal()">
            <i class="fa-solid fa-bullseye"></i> Criar meta
          </button>
        </div>
      </div>
    </div>

    <!-- ========== STATS ========== -->
    <div class="page" id="page-stats">
      <div class="grid-2" style="margin-bottom:1.5rem;">
        <div class="panel">
          <div class="panel-title">Receitas × Despesas (6 meses)</div>
          <div style="position:relative; height:240px;">
            <canvas id="bar-chart" role="img" aria-label="Gráfico de barras comparando receitas e despesas dos últimos 6 meses"></canvas>
          </div>
        </div>
        <div class="panel">
          <div class="panel-title">Distribuição de gastos</div>
          <div style="position:relative; height:240px;">
            <canvas id="donut-chart" role="img" aria-label="Gráfico de rosca com distribuição de gastos por categoria"></canvas>
          </div>
        </div>
      </div>
      <div class="panel">
        <div class="panel-title">Saldo acumulado (6 meses)</div>
        <div style="position:relative; height:200px;">
          <canvas id="balance-chart" role="img" aria-label="Gráfico de área mostrando evolução do saldo nos últimos 6 meses"></canvas>
        </div>
      </div>
    </div>
  </main>
</div>

<script>
// ============================================================
// DATA & DEFAULTS
// ============================================================
const MONTHS = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
const MONTHS_SHORT = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];

const CAT_COLORS = {
  'Alimentação':'#2e6db4','Transporte':'#d85a30','Saúde':'#1a9e72',
  'Lazer':'#b87515','Moradia':'#7a6fc0','Educação':'#0e7a6c',
  'Vestuário':'#c45580','Salário':'#1a9e72','Freelance':'#2bb5a0',
  'Assinaturas':'#6477b5','Investimentos':'#3a9e5a','Extras':'#8a7455','Outros':'#888780'
};

const CAT_ICONS = {
  'Alimentação':'fa-utensils','Transporte':'fa-car','Saúde':'fa-heart-pulse',
  'Lazer':'fa-gamepad','Moradia':'fa-house','Educação':'fa-book-open',
  'Vestuário':'fa-shirt','Salário':'fa-briefcase','Freelance':'fa-laptop',
  'Assinaturas':'fa-rotate','Investimentos':'fa-chart-line','Extras':'fa-star','Outros':'fa-ellipsis'
};

const PAGE_TITLES = {
  dashboard:'Painel', transactions:'Transações',
  add:'Nova Transação', goals:'Metas', stats:'Estatísticas'
};

let viewMonth = new Date().getMonth();
let viewYear  = new Date().getFullYear();
let txType    = 'expense';
let txFilter  = 'all';
let trendChart = null, barChart = null, donutChart = null, balanceChart = null;

function defaultData() {
  const y = new Date().getFullYear();
  const m = (new Date().getMonth() + 1).toString().padStart(2,'0');
  const pm = (new Date().getMonth()).toString().padStart(2,'0') || '12';
  const py = new Date().getMonth() === 0 ? y - 1 : y;
  return {
    transactions: [
      {id:1,desc:'Salário',amount:5500,type:'income',cat:'Salário',date:`${y}-${m}-01`},
      {id:2,desc:'Aluguel',amount:1400,type:'expense',cat:'Moradia',date:`${y}-${m}-05`},
      {id:3,desc:'Supermercado',amount:420,type:'expense',cat:'Alimentação',date:`${y}-${m}-07`},
      {id:4,desc:'Uber',amount:90,type:'expense',cat:'Transporte',date:`${y}-${m}-09`},
      {id:5,desc:'Freelance',amount:900,type:'income',cat:'Freelance',date:`${y}-${m}-12`},
      {id:6,desc:'Academia',amount:110,type:'expense',cat:'Saúde',date:`${y}-${m}-14`},
      {id:7,desc:'Netflix + Spotify',amount:75,type:'expense',cat:'Assinaturas',date:`${y}-${m}-15`},
      {id:8,desc:'Restaurante',amount:145,type:'expense',cat:'Alimentação',date:`${y}-${m}-18`},
      {id:9,desc:'Farmácia',amount:65,type:'expense',cat:'Saúde',date:`${y}-${m}-20`},
      {id:10,desc:'Salário anterior',amount:5500,type:'income',cat:'Salário',date:`${py}-${pm}-01`},
      {id:11,desc:'Aluguel anterior',amount:1400,type:'expense',cat:'Moradia',date:`${py}-${pm}-05`},
      {id:12,desc:'Mercado',amount:380,type:'expense',cat:'Alimentação',date:`${py}-${pm}-10`},
      {id:13,desc:'Freelance extra',amount:1200,type:'income',cat:'Freelance',date:`${py}-${pm}-15`},
    ],
    goals: [
      {id:1,name:'Viagem Europa',target:15000,saved:4500},
      {id:2,name:'Reserva de emergência',target:20000,saved:11000},
      {id:3,name:'Novo notebook',target:5000,saved:1800},
    ],
    nextId: 20
  };
}

let data = (() => {
  try { return JSON.parse(localStorage.getItem('financaspro_v2')) || defaultData(); }
  catch(e) { return defaultData(); }
})();

function save() {
  try { localStorage.setItem('financaspro_v2', JSON.stringify(data)); } catch(e){}
}

// ============================================================
// UTILS
// ============================================================
const fmt = v => 'R$ ' + Number(v).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2});
const fmtShort = v => v >= 1000 ? 'R$' + (v/1000).toFixed(1) + 'k' : 'R$' + v.toFixed(0);

function showToast(msg, color) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.style.background = color || 'var(--text)';
  t.style.color = 'var(--bg)';
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

function monthTx(m, y) {
  return data.transactions.filter(t => {
    const d = new Date(t.date + 'T12:00:00');
    return d.getMonth() === m && d.getFullYear() === y;
  });
}

// ============================================================
// NAVIGATION
// ============================================================
function switchPage(id, btn) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  if (btn) btn.classList.add('active');
  document.getElementById('page-heading').textContent = PAGE_TITLES[id] || '';
  closeSidebar();
  if (id === 'dashboard') renderDashboard();
  if (id === 'transactions') renderTransactions();
  if (id === 'goals') renderGoals();
  if (id === 'stats') renderStats();
}

function openSidebar()  { document.getElementById('sidebar').classList.add('open'); document.getElementById('sidebar-overlay').classList.add('open'); }
function closeSidebar() { document.getElementById('sidebar').classList.remove('open'); document.getElementById('sidebar-overlay').classList.remove('open'); }

// ============================================================
// THEME
// ============================================================
function toggleTheme() {
  const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
  document.documentElement.setAttribute('data-theme', isDark ? '' : 'dark');
  document.getElementById('theme-icon').className = isDark ? 'fa-solid fa-moon' : 'fa-solid fa-sun';
  document.getElementById('theme-label').textContent = isDark ? 'Modo escuro' : 'Modo claro';
  localStorage.setItem('fpro_theme', isDark ? '' : 'dark');
  renderDashboard();
  if (document.getElementById('page-stats').classList.contains('active')) renderStats();
}

// ============================================================
// MONTH NAV
// ============================================================
function changeMonth(dir) {
  viewMonth += dir;
  if (viewMonth < 0)  { viewMonth = 11; viewYear--; }
  if (viewMonth > 11) { viewMonth = 0;  viewYear++; }
  renderDashboard();
}

// ============================================================
// DASHBOARD
// ============================================================
function renderDashboard() {
  document.getElementById('month-display').textContent = MONTHS[viewMonth] + ' ' + viewYear;

  const txs     = monthTx(viewMonth, viewYear);
  const income  = txs.filter(t => t.type === 'income').reduce((s,t) => s + t.amount, 0);
  const expense = txs.filter(t => t.type === 'expense').reduce((s,t) => s + t.amount, 0);
  const balance = income - expense;
  const savings = income > 0 ? Math.round((balance / income) * 100) : 0;

  document.getElementById('metrics-grid').innerHTML = `
    <div class="metric-card">
      <div class="mc-label"><i class="fa-solid fa-arrow-down" style="color:var(--green)"></i> Receitas</div>
      <div class="mc-value green">${fmt(income)}</div>
      <div class="mc-sub">${txs.filter(t=>t.type==='income').length} entrada(s)</div>
    </div>
    <div class="metric-card">
      <div class="mc-label"><i class="fa-solid fa-arrow-up" style="color:var(--red)"></i> Despesas</div>
      <div class="mc-value red">${fmt(expense)}</div>
      <div class="mc-sub">${txs.filter(t=>t.type==='expense').length} gasto(s)</div>
    </div>
    <div class="metric-card">
      <div class="mc-label"><i class="fa-solid fa-wallet" style="color:var(--blue)"></i> Saldo</div>
      <div class="mc-value ${balance >= 0 ? 'green' : 'red'}">${fmt(balance)}</div>
      <div class="mc-sub">${balance >= 0 ? 'Mês positivo ✓' : 'Atenção: mês negativo'}</div>
    </div>
    <div class="metric-card">
      <div class="mc-label"><i class="fa-solid fa-piggy-bank" style="color:var(--purple)"></i> Poupado</div>
      <div class="mc-value ${savings >= 0 ? 'green' : 'red'}">${savings}%</div>
      <div class="mc-sub">da renda guardada</div>
    </div>
  `;

  // Category bars
  const cats = {};
  txs.filter(t => t.type === 'expense').forEach(t => { cats[t.cat] = (cats[t.cat] || 0) + t.amount; });
  const sorted = Object.entries(cats).sort((a,b) => b[1]-a[1]).slice(0, 7);
  const max = sorted[0]?.[1] || 1;
  document.getElementById('cat-bars').innerHTML = sorted.length
    ? sorted.map(([cat, val]) => `
        <div class="cat-row">
          <div class="cat-row-top">
            <span class="cat-name"><i class="fa-solid ${CAT_ICONS[cat]||'fa-circle'}" style="color:${CAT_COLORS[cat]||'#888'};font-size:13px"></i>${cat}</span>
            <span class="cat-val">${fmt(val)}</span>
          </div>
          <div class="bar-bg"><div class="bar-fill" style="width:${Math.round((val/max)*100)}%; background:${CAT_COLORS[cat]||'#888'};"></div></div>
        </div>`).join('')
    : '<div class="empty">Sem despesas neste mês.</div>';

  // Recent transactions
  document.getElementById('recent-list').innerHTML = data.transactions.slice(0, 6).map(txRow).join('') || '<div class="empty">Nenhuma transação ainda.</div>';

  // Trend chart
  renderTrendChart();
}

function txRow(t) {
  const isInc = t.type === 'income';
  const col = CAT_COLORS[t.cat] || '#888';
  const d = new Date(t.date + 'T12:00:00');
  return `<div class="tx-item">
    <div class="tx-icon" style="background:${col}22; color:${col};">
      <i class="fa-solid ${CAT_ICONS[t.cat]||'fa-circle'}"></i>
    </div>
    <div class="tx-info">
      <div class="tx-name">${t.desc}</div>
      <div class="tx-cat">${t.cat}</div>
    </div>
    <span class="tx-date">${d.toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'})}</span>
    <span class="tx-amount ${isInc?'inc':'exp'}">${isInc?'+':'-'}${fmt(t.amount)}</span>
    <button class="tx-delete" onclick="deleteTx(${t.id})" title="Excluir"><i class="fa-solid fa-trash-can"></i></button>
  </div>`;
}

function deleteTx(id) {
  if (!confirm('Excluir esta transação?')) return;
  data.transactions = data.transactions.filter(t => t.id !== id);
  save();
  renderDashboard();
  if (document.getElementById('page-transactions').classList.contains('active')) renderTransactions();
  showToast('Transação excluída.', '#d85a30');
}

function renderTrendChart() {
  const labels = [], incomes = [], expenses = [];
  for (let i = 5; i >= 0; i--) {
    let m = viewMonth - i, y = viewYear;
    if (m < 0) { m += 12; y--; }
    labels.push(MONTHS_SHORT[m]);
    const txs = monthTx(m, y);
    incomes.push(+txs.filter(t=>t.type==='income').reduce((s,t)=>s+t.amount,0).toFixed(2));
    expenses.push(+txs.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0).toFixed(2));
  }
  if (trendChart) trendChart.destroy();
  trendChart = new Chart(document.getElementById('trend-chart'), {
    type: 'line',
    data: {
      labels,
      datasets: [
        { label:'Receitas', data:incomes, borderColor:'#1a9e72', backgroundColor:'rgba(26,158,114,0.12)', tension:0.4, fill:true, pointRadius:3, pointBackgroundColor:'#1a9e72' },
        { label:'Despesas', data:expenses, borderColor:'#d85a30', backgroundColor:'rgba(216,90,48,0.08)', tension:0.4, fill:true, pointRadius:3, pointBackgroundColor:'#d85a30', borderDash:[5,3] }
      ]
    },
    options: {
      responsive:true, maintainAspectRatio:false,
      plugins:{legend:{display:false}},
      scales:{
        y:{ticks:{callback:v=>fmtShort(v),color:'#888',font:{size:11}}, grid:{color:'rgba(128,128,128,0.08)'}, border:{display:false}},
        x:{ticks:{color:'#888',font:{size:11}}, grid:{display:false}, border:{display:false}}
      }
    }
  });
}

// ============================================================
// TRANSACTIONS
// ============================================================
function setFilter(f, el) {
  txFilter = f;
  document.querySelectorAll('.filter-chip').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  renderTransactions();
}

function renderTransactions() {
  let txs = [...data.transactions];
  if (txFilter !== 'all') txs = txs.filter(t => t.type === txFilter);
  document.getElementById('all-tx-list').innerHTML = txs.length
    ? txs.map(txRow).join('')
    : '<div class="empty">Nenhuma transação encontrada.</div>';
}

// ============================================================
// ADD TRANSACTION
// ============================================================
function setTxType(t) {
  txType = t;
  document.getElementById('btn-exp').className = 'type-btn' + (t==='expense'?' active-exp':'');
  document.getElementById('btn-inc').className = 'type-btn' + (t==='income'?' active-inc':'');
}

function addTransaction() {
  const desc   = document.getElementById('tx-desc').value.trim();
  const amount = parseFloat(document.getElementById('tx-amount').value);
  const date   = document.getElementById('tx-date').value;
  const cat    = document.getElementById('tx-cat').value;
  const fb     = document.getElementById('add-feedback');

  if (!desc || !amount || !date) {
    fb.textContent = '⚠ Preencha todos os campos.';
    fb.style.color = 'var(--red)';
    return;
  }

  data.transactions.unshift({ id: data.nextId++, desc, amount, type: txType, cat, date });
  save();
  document.getElementById('tx-desc').value = '';
  document.getElementById('tx-amount').value = '';
  fb.textContent = '';
  showToast('✓ Transação adicionada!', '#1a9e72');
}

// ============================================================
// GOALS
// ============================================================
function addGoal() {
  const name   = document.getElementById('goal-name').value.trim();
  const target = parseFloat(document.getElementById('goal-target').value) || 0;
  const saved  = parseFloat(document.getElementById('goal-saved').value) || 0;
  if (!name || !target) { showToast('Preencha nome e valor alvo.', '#d85a30'); return; }
  data.goals.push({ id: data.nextId++, name, target, saved });
  save();
  document.getElementById('goal-name').value = '';
  document.getElementById('goal-target').value = '';
  document.getElementById('goal-saved').value = '';
  renderGoals();
  showToast('Meta criada!', '#1a9e72');
}

function deleteGoal(id) {
  if (!confirm('Excluir esta meta?')) return;
  data.goals = data.goals.filter(g => g.id !== id);
  save();
  renderGoals();
  showToast('Meta excluída.', '#d85a30');
}

function renderGoals() {
  document.getElementById('goals-list').innerHTML = data.goals.length
    ? data.goals.map(g => {
        const pct = Math.min(100, Math.round((g.saved / g.target) * 100));
        const remaining = Math.max(0, g.target - g.saved);
        return `<div class="goal-item">
          <div class="goal-header">
            <span class="goal-name">${g.name}</span>
            <div style="display:flex;align-items:center;gap:8px;">
              <span class="goal-pct">${pct}%</span>
              <button style="background:none;border:none;cursor:pointer;color:var(--text3);font-size:12px;" onclick="deleteGoal(${g.id})" title="Excluir"><i class="fa-solid fa-trash-can"></i></button>
            </div>
          </div>
          <div class="goal-bar-bg"><div class="goal-bar-fill" style="width:${pct}%"></div></div>
          <div class="goal-sub">
            <span>${fmt(g.saved)}</span>
            <span>Faltam ${fmt(remaining)} de ${fmt(g.target)}</span>
          </div>
        </div>`;
      }).join('')
    : '<div class="empty">Nenhuma meta criada.</div>';
}

// ============================================================
// STATS
// ============================================================
function renderStats() {
  const labels = [], incomes = [], expenses = [], balances = [];
  let running = 0;
  for (let i = 5; i >= 0; i--) {
    let m = new Date().getMonth() - i, y = new Date().getFullYear();
    if (m < 0) { m += 12; y--; }
    labels.push(MONTHS_SHORT[m]);
    const txs = monthTx(m, y);
    const inc = +txs.filter(t=>t.type==='income').reduce((s,t)=>s+t.amount,0).toFixed(2);
    const exp = +txs.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0).toFixed(2);
    incomes.push(inc); expenses.push(exp);
    running += inc - exp;
    balances.push(+running.toFixed(2));
  }

  if (barChart) barChart.destroy();
  barChart = new Chart(document.getElementById('bar-chart'), {
    type: 'bar',
    data: {
      labels,
      datasets: [
        { label:'Receitas', data:incomes, backgroundColor:'rgba(26,158,114,0.75)', borderRadius:4 },
        { label:'Despesas', data:expenses, backgroundColor:'rgba(216,90,48,0.75)', borderRadius:4 }
      ]
    },
    options: {
      responsive:true, maintainAspectRatio:false,
      plugins:{legend:{display:false}},
      scales:{
        y:{ticks:{callback:v=>fmtShort(v),color:'#888',font:{size:11}}, grid:{color:'rgba(128,128,128,0.08)'}, border:{display:false}},
        x:{ticks:{color:'#888',font:{size:11}}, grid:{display:false}, border:{display:false}}
      }
    }
  });

  // Donut
  const cats = {};
  const now2 = new Date();
  monthTx(now2.getMonth(), now2.getFullYear())
    .filter(t => t.type === 'expense')
    .forEach(t => { cats[t.cat] = (cats[t.cat]||0) + t.amount; });
  const catLabels = Object.keys(cats);
  const catVals = Object.values(cats);
  const catColors = catLabels.map(c => CAT_COLORS[c]||'#888');

  if (donutChart) donutChart.destroy();
  donutChart = new Chart(document.getElementById('donut-chart'), {
    type: 'doughnut',
    data: { labels:catLabels, datasets:[{ data:catVals, backgroundColor:catColors, borderWidth:0, hoverOffset:6 }] },
    options: {
      responsive:true, maintainAspectRatio:false, cutout:'65%',
      plugins:{
        legend:{ position:'right', labels:{ font:{size:11}, color:'#888', boxWidth:10, padding:10 } }
      }
    }
  });

  // Balance line
  if (balanceChart) balanceChart.destroy();
  balanceChart = new Chart(document.getElementById('balance-chart'), {
    type: 'line',
    data: {
      labels,
      datasets:[{
        label:'Saldo acumulado',
        data:balances,
        borderColor:'#2e6db4',
        backgroundColor:'rgba(46,109,180,0.12)',
        tension:0.4, fill:true,
        pointRadius:4, pointBackgroundColor:'#2e6db4'
      }]
    },
    options: {
      responsive:true, maintainAspectRatio:false,
      plugins:{legend:{display:false}},
      scales:{
        y:{ticks:{callback:v=>fmtShort(v),color:'#888',font:{size:11}}, grid:{color:'rgba(128,128,128,0.08)'}, border:{display:false}},
        x:{ticks:{color:'#888',font:{size:11}}, grid:{display:false}, border:{display:false}}
      }
    }
  });
}

// ============================================================
// EXPORT CSV
// ============================================================
function exportCSV() {
  const header = 'Data,Descrição,Categoria,Tipo,Valor\n';
  const rows = data.transactions.map(t =>
    `${t.date},"${t.desc}",${t.cat},${t.type==='income'?'Receita':'Despesa'},${t.amount.toFixed(2)}`
  ).join('\n');
  const blob = new Blob(['\uFEFF' + header + rows], { type: 'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = 'gastos.csv'; a.click();
  URL.revokeObjectURL(url);
  showToast('CSV exportado!', '#1a9e72');
}

// ============================================================
// INIT
// ============================================================
const now = new Date();
document.getElementById('today-str').textContent =
  now.toLocaleDateString('pt-BR',{weekday:'long', day:'numeric', month:'long', year:'numeric'});
document.getElementById('tx-date').value = now.toISOString().split('T')[0];

const savedTheme = localStorage.getItem('fpro_theme');
if (savedTheme === 'dark') {
  document.documentElement.setAttribute('data-theme','dark');
  document.getElementById('theme-icon').className = 'fa-solid fa-sun';
  document.getElementById('theme-label').textContent = 'Modo claro';
}

renderDashboard();
</script>
</body>
</html>
